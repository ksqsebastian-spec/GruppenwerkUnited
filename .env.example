# ============================================================
# Werkbank – Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# NIEMALS echte Werte in .env.example eintragen!
# ============================================================

# ------ Supabase (erforderlich) ----------------------------
# Zu finden unter: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key – NUR serverseitig (niemals NEXT_PUBLIC_ prefix!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ App-URL (erforderlich für CSRF-Schutz) -------------
# Lokale Entwicklung: http://localhost:3000
# Produktion: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Sicherheits-Secrets (erforderlich in Produktion) ---
# Zufälliger Secret für Cron-Job-Authentifizierung
# Generieren: openssl rand -base64 32
CRON_SECRET=

# HMAC-Secret für Supabase Database Webhooks
# Generieren: openssl rand -base64 32
SUPABASE_WEBHOOK_SECRET=

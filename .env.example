# ============================================================
# Werkbank – Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# NIEMALS echte Werte in .env.example eintragen!
# ============================================================

# ------ Supabase (erforderlich) ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ App-URL (erforderlich für CSRF-Schutz) -------------
# Lokale Entwicklung: http://localhost:3000
# Produktion: https://werkbank.gruppenwerk.de
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Sicherheits-Secrets (erforderlich in Produktion) ---
# Generieren: openssl rand -base64 32
SESSION_SECRET=
CRON_SECRET=

# ------ Firmen-Passwörter ----------------------------------
APP_PASSWORD=
ADMIN_PASSWORD=
SEEHAFER_PASSWORD=
BRINK_PASSWORD=
HANTKE_PASSWORD=
GRUPPENWERK_PASSWORD=
WERNER_PASSWORD=
MEHLIG_PASSWORD=

# ============================================================
# Werkbank – Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# NIEMALS echte Werte in .env.example eintragen!
# ============================================================

# ------ Datenbank (erforderlich) ---------------------------
# Sevalla: automatisch gesetzt durch interne Verbindung
# Lokale Entwicklung: postgresql://user:password@localhost:5432/werkbank
DATABASE_URL=postgresql://user:password@localhost:5432/werkbank

# ------ App-URL (erforderlich für CSRF-Schutz) -------------
# Lokale Entwicklung: http://localhost:3000
# Produktion: https://werkbank.gruppenwerk.de
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Sicherheits-Secrets (erforderlich in Produktion) ---
# Generieren: openssl rand -base64 32
SESSION_SECRET=
CRON_SECRET=

# ------ Firmen-Passwörter ----------------------------------
APP_PASSWORD=
ADMIN_PASSWORD=
SEEHAFER_PASSWORD=
BRINK_PASSWORD=
HANTKE_PASSWORD=
GRUPPENWERK_PASSWORD=
WERNER_PASSWORD=
MEHLIG_PASSWORD=
